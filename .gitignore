# Node / npm
node_modules/
npm-debug.log*

# Netlify CI installs functions/ deps fresh from
# netlify/functions/package.json at deploy time, so a local lockfile
# generated by `npm install` inside that directory is just developer
# noise. The root package-lock.json IS tracked (it pins the Vite +
# React graph for reproducible SPA builds).
netlify/functions/package-lock.json

# Vite build output. The active production deploy still serves
# index.html from the repo root; once the migration completes
# and netlify.toml's `publish` flips to "dist", Netlify will
# rebuild this on every deploy. Either way, it stays out of git.
dist/

# Generated at build time by scripts/gen-journal-posts.mjs (prebuild /
# prenext:build / pretypecheck) from src/data/journal-posts/*.md.
src/data/journalPostsData.js

# Generated at build time by scripts/gen-products.mjs from content/products/*.json.
src/data/cmsProductsData.generated.js

# Generated at build time by scripts/gen-pages.mjs from content/pages/*.json.
src/data/pagesData.generated.js

# Next.js (Vite→Next migration, Phase 2+). Build output, the
# auto-generated ambient types file, and the TS incremental cache
# (next build sets compilerOptions.incremental). Not served in
# production until the Phase 8 netlify.toml flip.
.next/
next-env.d.ts
*.tsbuildinfo

# Playwright test artifacts
test-results/
playwright-report/
.playwright-cache/

# Netlify CLI local state
.netlify/

# Environment-variable files (NEVER commit secrets)
.env
.env.*
!.env.example

# Editor / OS noise
.DS_Store
.vscode/
.idea/
*.swp
src/data/cmsCategoriesData.generated.js
exports/

# Rust / Tauri build output (Cargo.lock IS committed — it pins deps)
desktop/src-tauri/target/

# Portable environment (private local data — plan §23)
/portable/
desktop/game-mode/godot-project/.godot/
desktop/game-mode/godot-export/*
!desktop/game-mode/godot-export/.gitkeep
