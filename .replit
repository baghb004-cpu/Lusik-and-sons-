# Replit run config — the app lives in replit-app/ (everything else on
# this branch is frozen reference: ios/ is the SwiftUI app being mirrored,
# src/ + app/ are the production website). Importing this repo on the
# `replit` branch and pressing Run starts the dev server.

modules = ["nodejs-20"]
run = "sh -c 'cd replit-app && npm install && npm run dev'"
entrypoint = "replit-app/src/App.jsx"
hidden = [".git", ".next", "node_modules"]

[[ports]]
localPort = 3000
externalPort = 80

[deployment]
build = ["sh", "-c", "cd replit-app && npm install && npm run build"]
run = ["sh", "-c", "cd replit-app && npm run preview"]
deploymentTarget = "autoscale"
