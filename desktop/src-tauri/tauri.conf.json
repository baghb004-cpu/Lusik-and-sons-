{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Baghdo's Workshop",
  "version": "0.1.0",
  "identifier": "com.baghdo.workshop",
  "build": {
    "frontendDist": "../splash"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'"
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "icon": [
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
