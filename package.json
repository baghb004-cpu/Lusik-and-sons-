{
  "name": "lusik-and-sons",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Root package.json. Hosts the SPA build pipeline (Vite + Tailwind PostCSS — migration in progress, see CLAUDE.md § Vite migration) and the test harness (Playwright for browser smoke tests, Node's built-in test runner for backend unit tests). Functions have their OWN package.json under netlify/functions/ so the Stripe SDK can be marked as external — DO NOT MERGE the two graphs. `type: module` means root-level .js + src/**/*.js are interpreted as ESM (matches their `export` syntax); .mjs files and the netlify/functions/ subtree (which has its own package.json with `type: module` too) are unaffected.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "gen:journal": "node scripts/gen-journal-posts.mjs",
    "gen:sitemap": "node scripts/gen-journal-posts.mjs && node scripts/gen-sitemap.mjs",
    "predev": "node scripts/gen-journal-posts.mjs",
    "dev": "vite",
    "prebuild": "node scripts/gen-journal-posts.mjs",
    "build": "vite build",
    "preview": "vite preview",
    "prenext:dev": "node scripts/gen-journal-posts.mjs",
    "next:dev": "next dev",
    "prenext:build": "node scripts/gen-journal-posts.mjs",
    "next:build": "next build",
    "next:start": "next start",
    "pretypecheck": "node scripts/gen-journal-posts.mjs",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "node --test --test-reporter=spec netlify/functions/_lib/__tests__/*.test.mjs",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:install": "playwright install --with-deps chromium"
  },
  "dependencies": {
    "@netlify/blobs": "^10.7.8",
    "@netlify/functions": "^5.2.2",
    "@netlify/neon": "^0.1.0",
    "@sentry/react": "^10.54.0",
    "framer-motion": "^12.40.0",
    "next": "^14.2.35",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "stripe": "^22.2.0"
  },
  "devDependencies": {
    "@axe-core/react": "^4.11.3",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.48.0",
    "@types/node": "^25.9.1",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.5.15",
    "serve": "^14.2.4",
    "tailwindcss": "^3.4.0",
    "typescript": "^6.0.3",
    "vite": "^5.4.0"
  }
}
