{
  "name": "lusik-and-sons",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Root package.json. Hosts the Next.js (App Router) build + Tailwind PostCSS pipeline and the test harness (Playwright for browser smoke tests, Node's built-in test runner for backend unit tests). Functions have their OWN package.json under netlify/functions/ so the Stripe SDK can be marked as external — DO NOT MERGE the two graphs. `type: module` means root-level .js + src/**/*.js are interpreted as ESM (matches their `export` syntax); .mjs files and the netlify/functions/ subtree (which has its own package.json with `type: module` too) are unaffected.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "gen:journal": "node scripts/gen-journal-posts.mjs",
    "gen:products": "node scripts/gen-products.mjs",
    "gen:pages": "node scripts/gen-pages.mjs",
    "gen:data": "node scripts/gen-journal-posts.mjs && node scripts/gen-categories.mjs && node scripts/gen-products.mjs && node scripts/gen-pages.mjs",
    "gen:sitemap": "node scripts/gen-journal-posts.mjs && node scripts/gen-sitemap.mjs",
    "prenext:dev": "npm run gen:data",
    "next:dev": "next dev",
    "prenext:build": "npm run gen:data",
    "next:build": "next build",
    "next:start": "next start",
    "pretypecheck": "npm run gen:data",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:unit && npm run test:builder && npm run test:e2e",
    "pretest:unit": "npm run gen:data",
    "test:unit": "node --test --test-reporter=spec netlify/functions/_lib/__tests__/*.test.mjs",
    "test:builder": "node --test --test-reporter=spec \"src/builder/__tests__/*.test.ts\"",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:install": "playwright install --with-deps chromium",
    "postnext:build": "node scripts/check-bundle-budget.mjs",
    "analyze": "ANALYZE=true next build",
    "gen:categories": "node scripts/gen-categories.mjs"
  },
  "dependencies": {
    "@netlify/blobs": "^10.7.9",
    "@netlify/functions": "^5.3.0",
    "@netlify/neon": "^0.1.0",
    "@sentry/react": "^10.56.0",
    "framer-motion": "^12.40.0",
    "next": "^15.5.19",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "stripe": "^22.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/react": "^4.11.3",
    "@lhci/cli": "^0.15.1",
    "@next/bundle-analyzer": "^16.2.9",
    "@playwright/test": "^1.48.0",
    "@types/node": "^25.9.2",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.5.15",
    "serve": "^14.2.4",
    "tailwindcss": "^3.4.0",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "postcss": "^8.5.15",
    "tmp": "^0.2.7",
    "uuid": "^11.1.1"
  }
}
